{
  "info": {
    "name": "Wisata API - End to End Flow",
    "description": "Skenario pengujian lengkap API Wisata dari Registrasi hingga Review",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "adminToken",
      "value": "ISI_DENGAN_TOKEN_ADMIN_SETELAH_LOGIN"
    },
    {
      "key": "customerToken",
      "value": "ISI_DENGAN_TOKEN_CUSTOMER_SETELAH_LOGIN"
    }
  ],
  "item": [
    {
      "name": "1. Authentication",
      "item": [
        {
          "name": "1.1 Register Admin",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Super Admin\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\",\n  \"confirmPassword\": \"admin123\"\n}" },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "1.2 Register Customer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Budi Santoso\",\n  \"email\": \"budi@example.com\",\n  \"password\": \"budi123\",\n  \"confirmPassword\": \"budi123\"\n}" },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "1.3 Login Admin",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"admin123\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "1.4 Login Customer",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"budi@example.com\",\n  \"password\": \"budi123\"\n}" },
            "url": "{{baseUrl}}/auth/login"
          }
        }
      ]
    },
    {
      "name": "2. Admin - Setup Data",
      "item": [
        {
          "name": "2.1 Create Wisata",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}, {"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Curug Cibaliung\",\n  \"slug\": \"curug-cibaliung\",\n  \"location\": \"Bogor\",\n  \"description\": \"Wisata air terjun alami dengan air jernih dan suasana asri.\",\n  \"ticketPrice\": 25000,\n  \"capacity\": 100,\n  \"mapsUrl\": \"https://maps.google.com/?q=curug+cibaliung\",\n  \"isDisabilityFriendly\": false,\n  \"isKidsFree\": true,\n  \"imageUrl\": \"https://example.com/images/cibaliung.jpg\"\n}" },
            "url": "{{baseUrl}}/admin/wisata"
          }
        },
        {
          "name": "2.2 Create Schedule",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}, {"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"wisataId\": 1,\n  \"visitDate\": \"2026-06-01\",\n  \"quota\": 100\n}" },
            "url": "{{baseUrl}}/admin/schedules"
          }
        }
      ]
    },
    {
      "name": "3. Public Access",
      "item": [
        {
          "name": "3.1 Search Wisata",
          "request": { "method": "GET", "url": "{{baseUrl}}/wisata/search?q=curug&page=1" }
        },
        {
          "name": "3.2 Get Detail Wisata",
          "request": { "method": "GET", "url": "{{baseUrl}}/wisata/curug-cibaliung" }
        },
        {
          "name": "3.3 Get Available Schedules",
          "request": { "method": "GET", "url": "{{baseUrl}}/wisata/curug-cibaliung/schedules" }
        }
      ]
    },
    {
      "name": "4. Customer - Transaction",
      "item": [
        {
          "name": "4.1 Get Profile",
          "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{customerToken}}"}], "url": "{{baseUrl}}/profile" }
        },
        {
          "name": "4.2 Create Booking",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{customerToken}}"}, {"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"wisataId\": 1,\n  \"scheduleId\": 1,\n  \"totalTicket\": 3\n}" },
            "url": "{{baseUrl}}/bookings"
          }
        },
        {
          "name": "4.3 Upload Payment Proof",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{customerToken}}"}, {"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"bookingId\": 1,\n  \"paymentMethod\": \"QRIS Bank Mandiri\",\n  \"paymentProof\": \"http://localhost:8080/public/uploads/bukti_tf_budi.jpg\"\n}" },
            "url": "{{baseUrl}}/payments/upload"
          }
        }
      ]
    },
    {
      "name": "5. Admin - Verification & Check-in",
      "item": [
        {
          "name": "5.1 Get Bookings (Waiting Verification)",
          "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}], "url": "{{baseUrl}}/admin/bookings?status=WAITING_VERIFICATION" }
        },
        {
          "name": "5.2 Verify Payment",
          "request": { "method": "PUT", "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}], "url": "{{baseUrl}}/admin/bookings/1/verify" }
        },
        {
          "name": "5.3 Check My Active Tickets (Customer Side)",
          "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{customerToken}}"}], "url": "{{baseUrl}}/my-tickets" }
        },
        {
          "name": "5.4 Scan Ticket (Check-in)",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{adminToken}}"}, {"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"qrCode\": \"GANTI_DENGAN_QR_CODE_DARI_RESPONS_MY_TICKETS\"\n}" },
            "url": "{{baseUrl}}/admin/bookings/scan"
          }
        }
      ]
    },
    {
      "name": "6. Customer - Post Visit",
      "item": [
        {
          "name": "6.1 Get History",
          "request": { "method": "GET", "header": [{"key": "Authorization", "value": "Bearer {{customerToken}}"}], "url": "{{baseUrl}}/history" }
        },
        {
          "name": "6.2 Create Review",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{customerToken}}"}, {"key": "Content-Type", "value": "application/json"}],
            "body": { "mode": "raw", "raw": "{\n  \"bookingId\": 1,\n  \"rating\": 5,\n  \"comment\": \"Airnya sangat jernih dan fasilitas lengkap. Pasti akan kembali lagi!\"\n}" },
            "url": "{{baseUrl}}/reviews"
          }
        }
      ]
    }
  ]
}
